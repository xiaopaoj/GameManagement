<Window x:Class="GameManagement.SystemSaveDirectoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统存档目录设置" Height="570" Width="920" MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock x:Name="GameNameText" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="InitialScanText" Foreground="#59636E" Margin="0,5,0,10" TextWrapping="Wrap"/></StackPanel>
        <WrapPanel Grid.Row="1" Margin="0,0,0,8"><Button Content="添加目录" Click="Add_Click" Padding="14,8" Margin="4"/><Button Content="修改目录" Click="Edit_Click" Padding="14,8" Margin="4"/><Button Content="启用/禁用" Click="Toggle_Click" Padding="14,8" Margin="4"/><Button Content="删除目录配置" Click="Delete_Click" Padding="14,8" Margin="4"/><Button Content="重新执行首次常见目录扫描" Click="ResetInitialScan_Click" Padding="14,8" Margin="4"/></WrapPanel>
        <DataGrid x:Name="DirectoryGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns><DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/><DataGridTextColumn Header="状态" Binding="{Binding PathStatus}" Width="70"/><DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="150"/><DataGridCheckBoxColumn Header="自动发现" Binding="{Binding AutoDiscovered}" Width="80"/><DataGridTextColumn Header="目录" Binding="{Binding Path}" Width="*"/><DataGridTextColumn Header="最近扫描" Binding="{Binding LastScannedAt}" Width="150"/></DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="关闭" IsCancel="True" Padding="20,8"/></StackPanel>
    </Grid>
</Window>
