<Window x:Class="GameManagement.FilePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件预览" Height="680" Width="900" MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="PathText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="12">
            <Grid>
                <Image x:Name="ImagePreview" Stretch="Uniform" Visibility="Collapsed"/>
                <TextBox x:Name="TextPreview" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" BorderThickness="0"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="使用系统程序打开" Click="Open_Click" Padding="16,8" Margin="4"/><Button Content="关闭" IsCancel="True" Padding="18,8" Margin="4"/></StackPanel>
    </Grid>
</Window>
