<Window x:Class="GameManagement.DeletionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除历史" Height="580" Width="1050" MinHeight="450" MinWidth="820"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="删除与回收站操作历史" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTextColumn Header="对象" Binding="{Binding ObjectType}" Width="150"/>
                <DataGridTextColumn Header="方式" Binding="{Binding DeleteMethod}" Width="120"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="路径或名称" Binding="{Binding ObjectPath}" Width="4*"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Row="2" Content="关闭" IsCancel="True" HorizontalAlignment="Right" Padding="20,8" Margin="0,12,0,0"/>
    </Grid>
</Window>
