<Window x:Class="GameManagement.GameRecordDeletionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除游戏主记录" Height="590" Width="680" MinHeight="540" MinWidth="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="15"/>
        <ScrollViewer Grid.Row="1" Margin="0,16,0,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="VersionsCheck" Content="同步删除游戏版本记录（仅删除数据库记录，保留原始压缩包）" Margin="0,6"/>
                <CheckBox x:Name="PlayableCheck" Content="同步将可游玩目录移入 Windows 回收站" Margin="0,6"/>
                <CheckBox x:Name="LocalSaveCheck" Content="同步永久删除本地存档、快照、候选和规则" Margin="0,6"/>
                <CheckBox x:Name="SystemSaveCheck" Content="同步删除系统存档目录配置和已结束监控记录" Margin="0,6"/>
                <CheckBox x:Name="ExternalBackupCheck" Content="同步永久删除该游戏的外部 ZIP 备份文件和记录" Margin="0,6"/>
                <CheckBox x:Name="TemporaryCheck" Content="同步永久删除 GameTemp、GameSaveTemp 任务临时目录" Margin="0,6"/>
                <CheckBox x:Name="SourceLinksCheck" Content="解除已保留原始文件关联（不删除硬盘上的原始文件）" Margin="0,6"/>
                <Border Background="#FFF4D6" BorderBrush="#E0B95B" BorderThickness="1" Padding="12" Margin="0,14,0,0">
                    <TextBlock TextWrapping="Wrap" Text="警告：永久删除内容不会进入回收站。原始压缩包不会在此操作中删除；如需删除，仍必须使用独立的“删除原始文件”入口并完成两次确认。"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2">
            <TextBlock x:Name="NamePromptText" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <TextBox x:Name="CopyGameNameText" IsReadOnly="True" Padding="8" Margin="0,0,0,8" ToolTip="可选择并复制完整游戏名称"/>
            <TextBox x:Name="GameNameText" Padding="8"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" IsCancel="True" Padding="20,8" Margin="4"/>
            <Button Content="确认删除" IsDefault="True" Click="Confirm_Click" Padding="20,8" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
