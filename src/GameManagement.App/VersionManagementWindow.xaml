<Window x:Class="GameManagement.VersionManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="版本管理" Height="560" Width="920" MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="GameNameText" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="“设为当前版本”只修改未准备游戏；“切换并准备”会返回详情页执行归档、回收站清理、版本切换和重新准备。" Foreground="#59636E" Margin="0,5,0,12" TextWrapping="Wrap"/>
        </StackPanel>
        <DataGrid x:Name="VersionGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="版本名称" Binding="{Binding VersionName}" Width="150"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="160"/>
                <DataGridTextColumn Header="来源形式" Binding="{Binding SourceKind}" Width="120"/>
                <DataGridTextColumn Header="路径状态" Binding="{Binding SourcePathStatus}" Width="80"/>
                <DataGridTextColumn Header="文件数" Binding="{Binding SourceFileCount}" Width="75"/>
                <DataGridTextColumn Header="总体积" Binding="{Binding SourceSizeText}" Width="100"/>
                <DataGridTextColumn Header="原始路径" Binding="{Binding SourcePath}" Width="3*"/>
                <DataGridTextColumn Header="添加时间" Binding="{Binding CreatedAt}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="CurrentVersionText" Grid.Row="2" Margin="0,10,0,4" Foreground="#2C6E49" FontWeight="SemiBold"/>
        <DockPanel Grid.Row="3">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <WrapPanel>
                <Button Content="添加版本" Click="AddVersion_Click" Padding="14,8" Margin="4"/>
                <Button Content="编辑版本信息" Click="EditVersion_Click" Padding="14,8" Margin="4"/>
                <Button Content="设为当前版本" Click="SetCurrent_Click" Padding="14,8" Margin="4"/>
                <Button Content="切换并准备" Click="SwitchAndPrepare_Click" Padding="14,8" Margin="4"/>
                <Button Content="重新定位来源" Click="Relocate_Click" Padding="14,8" Margin="4"/>
                <Button Content="打开原始位置" Click="OpenSource_Click" Padding="14,8" Margin="4"/>
                <Button Content="删除版本记录" Click="DeleteVersion_Click" Padding="14,8" Margin="4"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
