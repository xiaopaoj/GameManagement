<Window x:Class="GameManagement.FeatureStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="330" Width="620" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="FeatureNameText" FontSize="25" FontWeight="SemiBold"/>
        <Border Grid.Row="1" Background="#FFF4CE" BorderBrush="#E5C365" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,14,0,12">
            <TextBlock Text="该功能入口已经建立，后端流程尚未完成。当前不会执行文件复制、解压、覆盖或删除操作。" TextWrapping="Wrap" Foreground="#674D00"/>
        </Border>
        <Border Grid.Row="2" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="功能说明" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap"/>
                <TextBlock x:Name="GameText" Margin="0,14,0,0" Foreground="#59636E" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <Button Grid.Row="3" Content="关闭" IsCancel="True" HorizontalAlignment="Right" Padding="22,8" Margin="0,14,0,0"/>
    </Grid>
</Window>
