<Window x:Class="GameManagement.SecurityWrapperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏工具箱" Height="640" Width="960" MinHeight="560" MinWidth="820"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="ToolCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="7"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style x:Key="ToolIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Foreground" Value="#2563A8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="ToolTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ToolDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#66717D"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件">
                <MenuItem Header="新建工具任务" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="工具">
                <MenuItem Header="存档目录助手" IsEnabled="False"/>
                <MenuItem Header="游戏时长计算" IsEnabled="False"/>
                <MenuItem Header="分辨率换算" IsEnabled="False"/>
                <MenuItem Header="文件校验工具" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="工具箱设置" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="使用说明" IsEnabled="False"/>
                <MenuItem Header="常见游戏目录" IsEnabled="False"/>
                <MenuItem Header="检查更新" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="检查数据完整性" Click="IntegrityCheck_Click"/>
                <Separator/>
                <MenuItem Header="关于游戏工具箱" IsEnabled="False"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="游戏工具箱已就绪" Foreground="#66717D"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28,24,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="7,0,7,18">
                    <TextBlock Text="游戏工具箱" FontSize="30" FontWeight="SemiBold"/>
                    <TextBlock Text="常用的游戏辅助工具集中在这里。工具功能将在后续版本逐步提供。"
                               Foreground="#66717D" FontSize="14" Margin="0,7,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="7,0,7,14" Padding="14,10" CornerRadius="8"
                        Background="#EAF3FC" BorderBrush="#C8DDF2" BorderThickness="1">
                    <TextBlock Text="当前版本提供基础界面预览，以下工具暂未开放。" Foreground="#315C86"/>
                </Border>

                <UniformGrid Grid.Row="2" Columns="3" Rows="2">
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE8B7;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="存档目录助手"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="快速定位常见的 Windows 游戏存档目录。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE823;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="游戏时长计算"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="根据开始和结束时间计算本次游玩时长。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE7F4;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="分辨率换算"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="换算常见显示分辨率、比例和缩放尺寸。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE9D9;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="文件校验工具"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="计算文件校验值，辅助确认文件完整性。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xEDA2;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="磁盘空间估算"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="换算存储单位并估算游戏所需磁盘空间。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolCardStyle}">
                        <StackPanel><TextBlock Style="{StaticResource ToolIconStyle}" Text="&#xE838;"/><TextBlock Style="{StaticResource ToolTitleStyle}" Text="快捷路径工具"/><TextBlock Style="{StaticResource ToolDescriptionStyle}" Text="集中查看常用的 Windows 用户目录位置。"/><TextBlock Text="即将推出" Foreground="#8A94A0" Margin="0,12,0,0"/></StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
