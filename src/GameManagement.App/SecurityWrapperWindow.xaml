<Window x:Class="GameManagement.SecurityWrapperWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="工具箱" Height="520" Width="820" MinHeight="420" MinWidth="680" WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8"/>
        <Button Grid.Row="1" Content="继续" HorizontalAlignment="Right" Margin="0,16,0,0" Padding="22,9" Click="Continue_Click"/>
    </Grid>
</Window>
