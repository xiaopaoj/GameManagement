<Window x:Class="GameManagement.TaskHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务历史" Height="620" Width="1100" MinHeight="480" MinWidth="880"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="持久化任务执行历史" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <DataGrid x:Name="TaskGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="任务" Binding="{Binding Name}" Width="190"/>
                <DataGridTextColumn Header="类型" Binding="{Binding TaskType}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="进度" Binding="{Binding ProgressText}" Width="70"/>
                <DataGridTextColumn Header="开始时间" Binding="{Binding StartedAt}" Width="155"/>
                <DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAt}" Width="155"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="3*"/>
                <DataGridTextColumn Header="当前或工作路径" Binding="{Binding CurrentPath}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <Button Content="查看错误详情" Click="ShowError_Click" Padding="14,8" Margin="4"/>
            <Button Content="打开保留的临时目录" Click="OpenFolder_Click" Padding="14,8" Margin="4"/>
        </DockPanel>
    </Grid>
</Window>
