<Window x:Class="GameManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏管理软件 1.0.0" Height="760" Width="1220"
        MinHeight="620" MinWidth="980" WindowStartupLocation="CenterScreen" Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="Button"><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4"/><Setter Property="MinWidth" Value="92"/></Style>
        <Style TargetType="DataGrid"><Setter Property="AutoGenerateColumns" Value="False"/><Setter Property="CanUserAddRows" Value="False"/><Setter Property="IsReadOnly" Value="True"/><Setter Property="GridLinesVisibility" Value="Horizontal"/></Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#243447" Padding="18,12">
            <Grid>
                <StackPanel><TextBlock Text="游戏管理软件" Foreground="White" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="原始压缩文件、游戏盘和存档统一管理" Foreground="#D5DEE8"/></StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <TabControl Margin="12">
            <TabItem Header="游戏库">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><Button Content="启动游戏" Command="{Binding LaunchGameCommand}"/><Button Content="打开游戏目录" Command="{Binding OpenGameFolderCommand}"/><Button Content="刷新" Command="{Binding ReloadCommand}"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}">
                        <DataGrid.Columns><DataGridTextColumn Header="游戏名称" Binding="{Binding DisplayName}" Width="2*"/><DataGridTextColumn Header="当前版本" Binding="{Binding CurrentVersionName}" Width="*"/><DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="原始路径" Binding="{Binding SourcePath}" Width="3*"/><DataGridTextColumn Header="上次游玩" Binding="{Binding LastPlayedAt}" Width="160"/></DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="文件扫描">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="140"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal"><Button Content="添加扫描路径" Command="{Binding AddScanPathCommand}"/><Button Content="删除扫描路径" Command="{Binding RemoveScanPathCommand}"/><Button Content="开始扫描" Command="{Binding ScanCommand}"/><CheckBox Content="隐藏已添加项目" IsChecked="{Binding HideAddedCandidates}" VerticalAlignment="Center" Margin="14,0"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ScanPaths}" SelectedItem="{Binding SelectedScanPath}"><DataGrid.Columns><DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/><DataGridTextColumn Header="扫描路径" Binding="{Binding Path}" Width="*"/><DataGridTextColumn Header="最近扫描" Binding="{Binding LastScannedAt}" Width="170"/></DataGrid.Columns></DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8"><Button Content="添加到游戏库" Command="{Binding AddCandidateToLibraryCommand}"/><TextBlock Text="候选文件由用户判断是否属于游戏，软件不会修改实际名称。" VerticalAlignment="Center" Foreground="#59636E"/></StackPanel>
                    <DataGrid Grid.Row="3" ItemsSource="{Binding VisibleCandidates}" SelectedItem="{Binding SelectedCandidate}"><DataGrid.Columns><DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="2*"/><DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="90"/><DataGridTextColumn Header="大小" Binding="{Binding DisplaySize}" Width="110"/><DataGridTextColumn Header="完整路径" Binding="{Binding FullPath}" Width="4*"/><DataGridCheckBoxColumn Header="已添加" Binding="{Binding Added}" Width="70"/></DataGrid.Columns></DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="游戏盘与设置">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="220"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal"><Button Content="添加游戏盘" Command="{Binding AddGameDiskCommand}"/><Button Content="删除游戏盘" Command="{Binding RemoveGameDiskCommand}"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding GameDisks}" SelectedItem="{Binding SelectedGameDisk}"><DataGrid.Columns><DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="150"/><DataGridTextColumn Header="工作根目录" Binding="{Binding RootPath}" Width="*"/><DataGridTextColumn Header="剩余空间" Binding="{Binding FreeSpaceText}" Width="130"/><DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/></DataGrid.Columns></DataGrid>
                    <TextBlock Grid.Row="2" Text="运行数据位置" FontWeight="SemiBold" Margin="0,14,0,6"/>
                    <Border Grid.Row="3" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="16"><StackPanel><TextBlock Text="{Binding ApplicationRoot}" FontSize="15"/><TextBlock Text="程序首次运行会在 EXE 所在目录创建 data 与 logs。目录不可写时会给出错误提示。" Foreground="#59636E" Margin="0,8,0,0"/><TextBlock Text="当前实现阶段：基础游戏库与路径扫描" Foreground="#2C6E49" Margin="0,18,0,0" FontWeight="SemiBold"/></StackPanel></Border>
                </Grid>
            </TabItem>
            <TabItem Header="任务中心">
                <Grid Margin="10"><DataGrid ItemsSource="{Binding Tasks}"><DataGrid.Columns><DataGridTextColumn Header="任务" Binding="{Binding Name}" Width="2*"/><DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120"/><DataGridTextColumn Header="进度" Binding="{Binding ProgressText}" Width="100"/><DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="4*"/><DataGridTextColumn Header="开始时间" Binding="{Binding StartedAt}" Width="170"/></DataGrid.Columns></DataGrid></Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
