<Window x:Class="GameManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏管理软件 1.0.0" Height="760" Width="1220"
        MinHeight="620" MinWidth="980" WindowStartupLocation="CenterScreen" Background="#F4F6F8"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Button"><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4"/><Setter Property="MinWidth" Value="92"/></Style>
        <Style TargetType="DataGrid"><Setter Property="AutoGenerateColumns" Value="False"/><Setter Property="CanUserAddRows" Value="False"/><Setter Property="IsReadOnly" Value="True"/><Setter Property="GridLinesVisibility" Value="Horizontal"/></Style>
    </Window.Resources>
    <Grid>
    <DockPanel IsEnabled="{Binding IsInterfaceEnabled}">
        <Border DockPanel.Dock="Top" Background="#243447" Padding="18,12">
            <Grid>
                <StackPanel><TextBlock Text="游戏管理软件" Foreground="White" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="原始压缩文件、游戏盘和存档统一管理" Foreground="#D5DEE8"/></StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <TabControl Margin="12">
            <TabItem Header="游戏库">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><Button Content="查看详情" Command="{Binding OpenGameDetailsCommand}"/><Button Content="启动游戏" Command="{Binding LaunchGameCommand}"/><Button Content="打开游戏目录" Command="{Binding OpenGameFolderCommand}"/><Button Content="刷新" Command="{Binding ReloadCommand}"/></StackPanel>
                    <DataGrid x:Name="GameGrid" Grid.Row="1" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}" MouseDoubleClick="GameGrid_MouseDoubleClick" PreviewMouseRightButtonDown="GameGrid_PreviewMouseRightButtonDown" RowHeight="44">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="查看详情" Click="GameContextMenu_Click"/>
                                <Separator/>
                                <MenuItem Header="准备游玩" Tag="准备游玩" Click="GameContextMenu_Click"/>
                                <MenuItem Header="编辑名称与备注" Tag="编辑名称与备注" Click="GameContextMenu_Click"/>
                                <MenuItem Header="启动游戏" Tag="启动游戏" Click="GameContextMenu_Click"/>
                                <MenuItem Header="归档游戏" Tag="归档游戏" Click="GameContextMenu_Click"/>
                                <MenuItem Header="特殊归档" Tag="特殊归档" Click="GameContextMenu_Click"/>
                                <MenuItem Header="手动备份" Tag="手动备份" Click="GameContextMenu_Click"/>
                                <Separator/>
                                <MenuItem Header="存档目录设置" Tag="存档目录设置" Click="GameContextMenu_Click"/>
                                <MenuItem Header="存档与快照" Tag="存档与快照" Click="GameContextMenu_Click"/>
                                <MenuItem Header="版本管理" Tag="版本管理" Click="GameContextMenu_Click"/>
                                <MenuItem Header="解压密码管理" Tag="解压密码管理" Click="GameContextMenu_Click"/>
                                <MenuItem Header="识别游戏目录" Tag="识别游戏目录" Click="GameContextMenu_Click"/>
                                <MenuItem Header="重新定位原始文件" Tag="重新定位原始文件" Click="GameContextMenu_Click"/>
                                <Separator/>
                                <MenuItem Header="打开原始位置" Tag="打开原始位置" Click="GameContextMenu_Click"/>
                                <MenuItem Header="打开游戏目录" Tag="打开游戏目录" Click="GameContextMenu_Click"/>
                                <Separator/>
                                <MenuItem Header="删除原始文件" Tag="删除原始文件" Click="GameContextMenu_Click"/>
                                <MenuItem Header="删除游戏主记录" Tag="删除游戏主记录" Click="GameContextMenu_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns><DataGridTemplateColumn Header="图标" Width="58"><DataGridTemplateColumn.CellTemplate><DataTemplate><Image Source="{Binding IconFullPath}" Width="36" Height="36" Stretch="Uniform"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTextColumn Header="游戏名称" Binding="{Binding DisplayName}" Width="2*"/><DataGridTextColumn Header="当前版本" Binding="{Binding CurrentVersionName}" Width="*"/><DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/><DataGridTextColumn Header="本地存档" Binding="{Binding LocalSaveStatus}" Width="75"/><DataGridTextColumn Header="原始状态" Binding="{Binding SourcePathStatus}" Width="75"/><DataGridTextColumn Header="原始路径" Binding="{Binding SourcePath}" Width="3*"/><DataGridTextColumn Header="上次游玩" Binding="{Binding LastPlayedAt}" Width="150"/></DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="文件扫描">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="140"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal"><Button Content="添加扫描路径" Command="{Binding AddScanPathCommand}"/><Button Content="删除扫描路径" Command="{Binding RemoveScanPathCommand}"/><Button Content="重新定位路径" Command="{Binding RelocateScanPathCommand}"/><Button Content="启用/禁用" Command="{Binding ToggleScanPathCommand}"/><Button Content="开始扫描" Command="{Binding ScanCommand}"/><CheckBox Content="隐藏已添加项目" IsChecked="{Binding HideAddedCandidates}" VerticalAlignment="Center" Margin="14,0"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ScanPaths}" SelectedItem="{Binding SelectedScanPath}"><DataGrid.Columns><DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/><DataGridTextColumn Header="状态" Binding="{Binding PathStatus}" Width="65"/><DataGridTextColumn Header="磁盘" Binding="{Binding DriveName}" Width="70"/><DataGridTextColumn Header="剩余空间" Binding="{Binding FreeSpaceText}" Width="110"/><DataGridTextColumn Header="扫描路径" Binding="{Binding Path}" Width="*"/><DataGridTextColumn Header="最近扫描" Binding="{Binding LastScannedAt}" Width="160"/></DataGrid.Columns></DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8"><Button Content="添加到游戏库" Command="{Binding AddCandidateToLibraryCommand}" CommandParameter="{Binding SelectedItems, ElementName=CandidateGrid}"/><TextBlock Text="支持多选；添加时记录来源大小、修改时间和 SHA-256 指纹。" VerticalAlignment="Center" Foreground="#59636E"/></StackPanel>
                    <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                        <TextBlock Text="名称或路径" VerticalAlignment="Center"/><TextBox Text="{Binding CandidateSearchText, UpdateSourceTrigger=PropertyChanged}" Width="210" Margin="6,0,14,0"/>
                        <TextBlock Text="类型" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding CandidateKindOptions}" SelectedItem="{Binding CandidateKindFilter}" Width="130" Margin="6,0,14,0"/>
                        <TextBlock Text="磁盘" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding CandidateDriveOptions}" SelectedItem="{Binding CandidateDriveFilter}" Width="90" Margin="6,0,14,0"/>
                        <TextBlock Text="添加状态" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding CandidateAddedOptions}" SelectedItem="{Binding CandidateAddedFilter}" Width="90" Margin="6,0,0,0"/>
                    </WrapPanel>
                    <DataGrid x:Name="CandidateGrid" Grid.Row="4" ItemsSource="{Binding VisibleCandidates}" SelectionMode="Extended" SelectionUnit="FullRow"><DataGrid.Columns><DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="2*"/><DataGridTextColumn Header="来源形式" Binding="{Binding Kind}" Width="120"/><DataGridTextColumn Header="压缩包" Binding="{Binding ArchiveSummary}" Width="90"/><DataGridTextColumn Header="大小" Binding="{Binding DisplaySize}" Width="100"/><DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedAt}" Width="150"/><DataGridTextColumn Header="磁盘" Binding="{Binding DriveName}" Width="70"/><DataGridTextColumn Header="完整路径" Binding="{Binding FullPath}" Width="4*"/><DataGridCheckBoxColumn Header="有效" Binding="{Binding PathValid, Mode=OneWay}" Width="55"/><DataGridCheckBoxColumn Header="已添加" Binding="{Binding Added, Mode=OneWay}" Width="70"/></DataGrid.Columns></DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="设置">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="220"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal"><Button Content="添加游戏盘" Command="{Binding AddGameDiskCommand}"/><Button Content="编辑游戏盘" Command="{Binding EditGameDiskCommand}"/><Button Content="删除游戏盘" Command="{Binding RemoveGameDiskCommand}"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding GameDisks}" SelectedItem="{Binding SelectedGameDisk}"><DataGrid.Columns><DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="130"/><DataGridCheckBoxColumn Header="默认" Binding="{Binding IsDefault}" Width="55"/><DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="55"/><DataGridTextColumn Header="状态" Binding="{Binding PathStatus}" Width="65"/><DataGridTextColumn Header="磁盘类型" Binding="{Binding DiskTypeText}" Width="95"/><DataGridTextColumn Header="总容量" Binding="{Binding TotalSpaceText}" Width="100"/><DataGridTextColumn Header="剩余空间" Binding="{Binding FreeSpaceText}" Width="100"/><DataGridTextColumn Header="最低保留" Binding="{Binding MinimumFreeSpaceText}" Width="100"/><DataGridTextColumn Header="工作根目录" Binding="{Binding RootPath}" Width="*"/></DataGrid.Columns></DataGrid>
                    <TextBlock Grid.Row="2" Text="运行数据位置" FontWeight="SemiBold" Margin="0,14,0,6"/>
                    <Border Grid.Row="3" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="16"><StackPanel><TextBlock Text="{Binding ApplicationRoot}" FontSize="15"/><TextBlock Text="程序首次运行会在 EXE 所在目录创建 data 与 logs。目录不可写时会给出错误提示。" Foreground="#59636E" Margin="0,8,0,0"/><TextBlock Text="当前版本状态：1.0.0 已完成验收" Foreground="#2C6E49" Margin="0,18,0,0" FontWeight="SemiBold"/></StackPanel></Border>
                </Grid>
            </TabItem>
            <TabItem Header="任务中心">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"><Button Content="查看任务详情" Command="{Binding ShowTaskErrorCommand}"/><Button Content="打开临时目录" Command="{Binding OpenTaskFolderCommand}"/><Button Content="清理临时目录" Command="{Binding CleanupTaskTempCommand}"/><Button Content="打开关联游戏" Command="{Binding OpenTaskGameCommand}"/></StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}"><DataGrid.Columns><DataGridTextColumn Header="任务" Binding="{Binding Name}" Width="170"/><DataGridTextColumn Header="类型" Binding="{Binding TaskType}" Width="100"/><DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/><DataGridTextColumn Header="进度" Binding="{Binding ProgressText}" Width="70"/><DataGridTextColumn Header="当前路径" Binding="{Binding CurrentPath}" Width="2*"/><DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="3*"/><DataGridTextColumn Header="开始时间" Binding="{Binding StartedAt}" Width="150"/><DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAt}" Width="150"/></DataGrid.Columns></DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="存档管理">
                <Grid Margin="18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="存档管理" FontSize="24" FontWeight="SemiBold"/>
                    <WrapPanel Grid.Row="1" Margin="0,16,0,12"><Button Content="正常存档快照" Click="NormalSnapshots_Click"/><Button Content="异常存档快照" Click="AbnormalSnapshots_Click"/><Button Content="存档目录规则" Click="SaveRules_Click"/><Button Content="待确认存档候选" Click="SaveCandidates_Click"/></WrapPanel>
                    <Border Grid.Row="2" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="18"><TextBlock Text="此页面用于集中查看所有游戏的本地存档、正常与异常快照、已确认存档目录和待确认候选。" TextWrapping="Wrap" Foreground="#59636E"/></Border>
                </Grid>
            </TabItem>
            <TabItem Header="备份管理">
                <Grid Margin="18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="备份管理" FontSize="24" FontWeight="SemiBold"/>
                    <WrapPanel Grid.Row="1" Margin="0,16,0,12"><Button Content="外部备份列表" Click="BackupList_Click"/><Button Content="每日计划备份" Click="BackupSchedule_Click"/><Button Content="等待补执行" Click="PendingBackups_Click"/><Button Content="超额备份清理" Click="BackupCleanup_Click"/></WrapPanel>
                    <Border Grid.Row="2" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="18"><TextBlock Text="此页面用于查看手动备份、完整 GameSave 每日备份、校验结果、等待磁盘任务和人工恢复说明。" TextWrapping="Wrap" Foreground="#59636E"/></Border>
                </Grid>
            </TabItem>
            <TabItem Header="操作历史">
                <Grid Margin="18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="操作历史" FontSize="24" FontWeight="SemiBold"/>
                    <WrapPanel Grid.Row="1" Margin="0,16,0,12"><Button Content="任务历史" Click="TaskHistory_Click"/><Button Content="备份历史" Click="BackupHistory_Click"/><Button Content="删除历史" Click="DeleteHistory_Click"/><Button Content="打开日志目录" Click="OpenLogs_Click"/></WrapPanel>
                    <Border Grid.Row="2" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="18"><TextBlock Text="此页面用于查询复制、解压、启动、存档、备份、归档和删除操作的历史记录。" TextWrapping="Wrap" Foreground="#59636E"/></Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
        <Border Background="#B3000000" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100">
            <Border Background="White" BorderBrush="#BCC5CE" BorderThickness="1" CornerRadius="6" Padding="24" Width="680" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="正在扫描游戏文件" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="扫描完成前已暂停其他界面操作。文件夹内部压缩包将在准备游玩时递归识别。" TextWrapping="Wrap" Foreground="#59636E" Margin="0,8,0,16"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ScanProgress}" Height="20"/>
                    <TextBlock Text="{Binding ScanProgress, StringFormat=扫描进度：{0}%}" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <TextBlock Text="{Binding ScanProgressMessage}" TextWrapping="Wrap" Foreground="#59636E" MaxHeight="70"/>
                    <Button Content="取消扫描" Command="{Binding CancelScanCommand}" HorizontalAlignment="Right" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
