<Window x:Class="GameManagement.EncryptedLogViewerWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="加密运行日志" Height="700" Width="1050" MinHeight="520" MinWidth="800" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <ListBox x:Name="LogList" DisplayMemberPath="Name" SelectionChanged="LogList_SelectionChanged"/>
        <TextBox x:Name="LogContent" Grid.Column="1" Margin="12,0,0,0" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"/>
        <Button Grid.Row="1" Grid.ColumnSpan="2" Content="关闭" IsCancel="True" HorizontalAlignment="Right" Margin="0,12,0,0" Padding="20,8"/>
    </Grid>
</Window>
