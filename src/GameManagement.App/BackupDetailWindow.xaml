<Window x:Class="GameManagement.BackupDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备份内容与人工恢复说明" Height="700" Width="1080" MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="2*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="ZIP 文件内容（只读）" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock x:Name="SummaryText" Foreground="#59636E" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>
        <DataGrid x:Name="FileGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ZIP 内路径" Binding="{Binding ZipPath}" Width="3*"/>
                <DataGridTextColumn Header="原始恢复路径" Binding="{Binding OriginalRestorePath}" Width="3*"/>
                <DataGridTextColumn Header="大小" Binding="{Binding FileSize}" Width="100"/>
                <DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="260"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBox x:Name="InstructionsText" Grid.Row="2" Margin="0,12,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10"/>
        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <Button Content="复制所选恢复路径" Click="CopyPath_Click" Padding="14,8" Margin="4"/>
        </DockPanel>
    </Grid>
</Window>
