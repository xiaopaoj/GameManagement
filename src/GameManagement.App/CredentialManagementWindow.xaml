<Window x:Class="GameManagement.CredentialManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="解压密码管理" Height="520" Width="900" MinHeight="440" MinWidth="760"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="GameNameText" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="密码默认不显示，只有点击“查看密码”后才会通过当前 Windows 用户的 DPAPI 解密。" Foreground="#59636E" Margin="0,5,0,12"/>
        </StackPanel>
        <DataGrid x:Name="CredentialGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="版本" Binding="{Binding VersionName}" Width="150"/>
                <DataGridTextColumn Header="步骤" Binding="{Binding StepName}" Width="90"/>
                <DataGridTextColumn Header="压缩文件" Binding="{Binding ArchiveName}" Width="180"/>
                <DataGridTextColumn Header="相对路径" Binding="{Binding RelativePath}" Width="2*"/>
                <DataGridTextColumn Header="最近验证" Binding="{Binding VerifiedAt}" Width="150"/>
                <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAt}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <WrapPanel>
                <Button Content="查看密码" Click="View_Click" Padding="14,8" Margin="4"/>
                <Button Content="修改密码" Click="Modify_Click" Padding="14,8" Margin="4"/>
                <Button Content="删除密码" Click="Delete_Click" Padding="14,8" Margin="4"/>
                <Button Content="重新验证" Click="Validate_Click" Padding="14,8" Margin="4"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
