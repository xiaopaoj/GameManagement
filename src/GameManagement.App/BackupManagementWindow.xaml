<Window x:Class="GameManagement.BackupManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="外部备份管理" Height="650" Width="1120" MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="外部 ZIP 备份" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock x:Name="StatusText" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#59636E"/>
        </DockPanel>
        <DataGrid x:Name="BackupGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="类型" Binding="{Binding BackupKind}" Width="160"/>
                <DataGridTextColumn Header="游戏 ID" Binding="{Binding GameId}" Width="220"/>
                <DataGridTextColumn Header="大小" Binding="{Binding FileSizeText}" Width="90"/>
                <DataGridTextColumn Header="校验" Binding="{Binding VerifiedText}" Width="80"/>
                <DataGridTextColumn Header="保留" Binding="{Binding CleanupSuggestionText}" Width="80"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTextColumn Header="ZIP 路径" Binding="{Binding FilePath}" Width="4*"/>
                <DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="260"/>
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <WrapPanel>
                <Button Content="查看内容与恢复说明" Click="View_Click" Padding="12,8" Margin="4"/>
                <Button Content="重新校验" Click="Verify_Click" Padding="12,8" Margin="4"/>
                <Button Content="系统打开 ZIP" Click="OpenZip_Click" Padding="12,8" Margin="4"/>
                <Button Content="打开所在目录" Click="OpenFolder_Click" Padding="12,8" Margin="4"/>
                <Button Content="永久删除备份" Click="Delete_Click" Padding="12,8" Margin="4"/>
                <Button Content="刷新" Click="Refresh_Click" Padding="12,8" Margin="4"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
