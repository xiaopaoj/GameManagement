<Window x:Class="GameManagement.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏详情" Height="730" Width="920" MinHeight="650" MinWidth="780"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{Binding DisplayName}" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Status, StringFormat=当前状态：{0}}" Foreground="#59636E" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="16" Margin="0,16,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="游戏 ID" FontWeight="SemiBold"/><TextBox Grid.Column="1" Text="{Binding Id}" IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
                <TextBlock Grid.Row="1" Text="当前版本" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentVersionName}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="2" Text="来源形式" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SourceKind}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="3" Text="原始路径" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SourcePath}" IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="4" Text="可游玩目录" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PlayableRootPath, TargetNullValue=尚未准备}" IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="5" Text="启动文件" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ExecutableRelativePath, TargetNullValue=尚未设置}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="6" Text="上次游玩" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LastPlayedAt, TargetNullValue=暂无记录}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="7" Text="备注" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Note}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="8" Text="版本数量" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Versions.Count}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="9" Text="原始路径状态" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SourcePathStatus}" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <GroupBox Grid.Row="2" Header="版本列表" Padding="8">
            <DataGrid ItemsSource="{Binding Versions}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="版本名称" Binding="{Binding VersionName}" Width="2*"/>
                    <DataGridTextColumn Header="版本备注" Binding="{Binding Note}" Width="2*"/>
                    <DataGridTextColumn Header="来源形式" Binding="{Binding SourceKind}" Width="120"/>
                    <DataGridTextColumn Header="路径状态" Binding="{Binding SourcePathStatus}" Width="80"/>
                    <DataGridTextColumn Header="总体积" Binding="{Binding SourceSizeText}" Width="100"/>
                    <DataGridTextColumn Header="原始路径" Binding="{Binding SourcePath}" Width="4*"/>
                    <DataGridTextColumn Header="添加时间" Binding="{Binding CreatedAt}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4" VerticalAlignment="Bottom"/>
            <WrapPanel>
                <Button Content="准备游玩" Click="Prepare_Click" Padding="14,8" Margin="4"/>
                <Button Content="编辑名称与备注" Click="EditGame_Click" Padding="14,8" Margin="4"/>
                <Button Content="启动游戏" Click="Launch_Click" Padding="14,8" Margin="4"/>
                <Button Content="归档游戏" Click="Archive_Click" Padding="14,8" Margin="4"/>
                <Button Content="特殊归档" Click="SpecialArchive_Click" Padding="14,8" Margin="4"/>
                <Button Content="手动备份" Click="ManualBackup_Click" Padding="14,8" Margin="4"/>
                <Button Content="存档目录设置" Click="SaveDirectories_Click" Padding="14,8" Margin="4"/>
                <Button Content="存档与快照" Click="Snapshots_Click" Padding="14,8" Margin="4"/>
                <Button Content="版本管理" Click="Versions_Click" Padding="14,8" Margin="4"/>
                <Button Content="识别游戏目录" Click="RecognizeGame_Click" Padding="14,8" Margin="4"/>
                <Button Content="重新定位原始文件" Click="RelocateSource_Click" Padding="14,8" Margin="4"/>
                <Button Content="删除原始文件" Click="DeleteSource_Click" Padding="14,8" Margin="4"/>
                <Button Content="打开原始位置" Click="OpenSource_Click" Padding="14,8" Margin="4"/>
                <Button Content="打开游戏目录" Click="OpenPlayable_Click" Padding="14,8" Margin="4"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
