<Window x:Class="GameManagement.SecurityModeSettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="安全密码模式" Width="580" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="ModeStatusText" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="数据库始终保持 AES-256-GCM 密文。安全模式只控制启动时是否必须输入密码；忘记密码时当前版本无法恢复或重置。" TextWrapping="Wrap" Foreground="#8A5A00" Margin="0,8,0,16"/>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="当前密码" VerticalAlignment="Center"/><PasswordBox x:Name="CurrentPasswordText" Grid.Column="1" Padding="8"/></Grid>
        <Grid Grid.Row="3" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="新密码" VerticalAlignment="Center"/><PasswordBox x:Name="NewPasswordText" Grid.Column="1" Padding="8"/></Grid>
        <Grid Grid.Row="4" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="确认新密码" VerticalAlignment="Center"/><PasswordBox x:Name="ConfirmPasswordText" Grid.Column="1" Padding="8"/></Grid>
        <StackPanel Grid.Row="5" Margin="0,14,0,0"><CheckBox x:Name="RiskCheck" Content="我已了解：忘记安全密码时当前版本无法恢复或重置数据" Margin="0,0,0,10"/><WrapPanel><Button Content="开启安全模式" Click="Enable_Click"/><Button Content="修改密码" Click="Change_Click"/><Button Content="关闭安全模式" Click="Disable_Click"/><Button Content="关闭窗口" IsCancel="True"/></WrapPanel></StackPanel>
    </Grid>
</Window>
