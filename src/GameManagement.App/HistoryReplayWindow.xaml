<Window x:Class="GameManagement.HistoryReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史解压流程" Height="260" Width="620" MinHeight="240" MinWidth="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" FontSize="15" TextWrapping="Wrap"/>
        <CheckBox x:Name="AutoReplayCheck" Grid.Row="1" Margin="0,16,0,8"
                  Content="后续解压步骤均自动使用历史选择和已保存密码"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="否" IsCancel="True" Click="No_Click" Padding="24,8" Margin="4"/>
            <Button Content="是" IsDefault="True" Click="Yes_Click" Padding="24,8" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
