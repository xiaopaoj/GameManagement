<Window x:Class="GameManagement.PreparationProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="220" Width="560" ResizeMode="CanMinimize" WindowStartupLocation="CenterOwner" ShowInTaskbar="True" Closing="Window_Closing" IsVisibleChanged="Window_IsVisibleChanged">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" Text="正在准备游戏" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock x:Name="StatusText" Grid.Row="1" Text="正在初始化…" TextWrapping="Wrap" Margin="0,16,0,10"/>
        <ProgressBar x:Name="Progress" Grid.Row="2" Height="16" IsIndeterminate="True" Minimum="0" Maximum="100"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="后台运行" Padding="18,7" Margin="0,0,8,0" Click="Background_Click" ToolTip="隐藏此进度窗口，任务继续运行；可在任务中心查看状态"/>
            <Button x:Name="CancelButton" Content="取消任务" Visibility="Collapsed" Padding="18,7" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
