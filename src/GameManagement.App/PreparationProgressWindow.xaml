<Window x:Class="GameManagement.PreparationProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="210" Width="560" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Closing="Window_Closing">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" Text="正在准备游戏" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock x:Name="StatusText" Grid.Row="1" Text="正在初始化…" TextWrapping="Wrap" Margin="0,16,0,10"/>
        <ProgressBar x:Name="Progress" Grid.Row="2" Height="16" IsIndeterminate="True" Minimum="0" Maximum="100"/>
        <Button x:Name="CancelButton" Grid.Row="3" Content="取消任务" Visibility="Collapsed" HorizontalAlignment="Right" Margin="0,14,0,0" Padding="18,7" Click="Cancel_Click"/>
    </Grid>
</Window>
