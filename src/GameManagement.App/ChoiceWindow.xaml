<Window x:Class="GameManagement.ChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="460" Width="760" MinHeight="360" MinWidth="620" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <DataGrid x:Name="ChoiceGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" MouseDoubleClick="ChoiceGrid_MouseDoubleClick">
            <DataGrid.Columns><DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="2*"/><DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="4*"/></DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="取消" IsCancel="True" Padding="18,8" Margin="4"/><Button Content="确定" IsDefault="True" Click="Confirm_Click" Padding="18,8" Margin="4"/></StackPanel>
    </Grid>
</Window>
