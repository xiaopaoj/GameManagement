<Window x:Class="GameManagement.ExecutableIgnoreListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EXE 忽略清单" Height="520" Width="620" MinHeight="420" MinWidth="520"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="扫描游戏目录时，清单中的 EXE 不用于确定游戏目录。按完整文件名匹配，忽略大小写。" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <ListBox x:Name="IgnoreList" Grid.Row="1" FontSize="14"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="新增" Click="Add_Click" Padding="14,7" Margin="4"/>
            <Button Content="编辑" Click="Edit_Click" Padding="14,7" Margin="4"/>
            <Button Content="删除" Click="Delete_Click" Padding="14,7" Margin="4"/>
            <Button Content="关闭" Click="Close_Click" Padding="14,7" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
