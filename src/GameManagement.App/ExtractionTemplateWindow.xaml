<Window x:Class="GameManagement.ExtractionTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="解压流程模板" Height="520" Width="760" MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DataGrid x:Name="TemplateGrid" ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionChanged="TemplateGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="模板名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAt}" Width="170"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1" Margin="0,14,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="模板名称" VerticalAlignment="Center"/><TextBox x:Name="NameText" Grid.Column="1" Margin="4"/>
            <TextBlock Grid.Row="1" Text="第一次解压密码" VerticalAlignment="Center"/><TextBox x:Name="FirstPasswordText" Grid.Row="1" Grid.Column="1" Margin="4"/>
            <TextBlock Grid.Row="2" Text="第二次解压密码" VerticalAlignment="Center"/><TextBox x:Name="SecondPasswordText" Grid.Row="2" Grid.Column="1" Margin="4"/>
        </Grid>
        <DockPanel Grid.Row="2">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="18,8" Margin="4"/>
            <WrapPanel><Button Content="新增" Click="Add_Click" Padding="16,8" Margin="4"/><Button Content="保存修改" Click="Save_Click" Padding="16,8" Margin="4"/><Button Content="删除" Click="Delete_Click" Padding="16,8" Margin="4"/></WrapPanel>
        </DockPanel>
    </Grid>
</Window>
