<Window x:Class="GameManagement.BackupScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="每日计划备份" Height="500" Width="780" MinHeight="440" MinWidth="680"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="完整 GameSave 每日计划备份" FontSize="24" FontWeight="SemiBold"/>
        <Border Grid.Row="1" Background="White" BorderBrush="#DCE1E6" BorderThickness="1" Padding="18" Margin="0,14,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="外部备份目录" FontWeight="SemiBold"/><TextBox x:Name="DirectoryText" Grid.Column="1" IsReadOnly="True" TextWrapping="Wrap"/>
                <Button Grid.Row="1" Grid.Column="1" Content="选择备份目录" Click="PickDirectory_Click" HorizontalAlignment="Left" Margin="0,8,0,0" Padding="12,6"/>
                <TextBlock Grid.Row="2" Text="每日执行时间" FontWeight="SemiBold" Margin="0,12,0,0"/><TextBox x:Name="TimeText" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Width="120" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="3" Text="计划状态" FontWeight="SemiBold" Margin="0,12,0,0"/><CheckBox x:Name="EnabledCheck" Grid.Row="3" Grid.Column="1" Content="启用 Windows 每日计划任务" Margin="0,12,0,0"/>
                <TextBlock Grid.Row="4" Text="最近执行" FontWeight="SemiBold" Margin="0,12,0,0"/><TextBlock x:Name="LastRunText" Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="5" Text="离线补执行" FontWeight="SemiBold" Margin="0,12,0,0"/><TextBlock x:Name="PendingText" Grid.Row="5" Grid.Column="1" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </Grid>
        </Border>
        <DockPanel Grid.Row="2">
            <Button DockPanel.Dock="Right" Content="关闭" IsCancel="True" Padding="20,8" Margin="4"/>
            <WrapPanel>
                <Button Content="保存设置" Click="Save_Click" Padding="14,8" Margin="4"/>
                <Button Content="立即执行完整备份" Click="RunNow_Click" Padding="14,8" Margin="4"/>
                <Button Content="查看外部备份" Click="ViewBackups_Click" Padding="14,8" Margin="4"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
