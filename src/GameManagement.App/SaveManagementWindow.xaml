<Window x:Class="GameManagement.SaveManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="存档与快照" Height="760" Width="1180" MinHeight="620" MinWidth="920"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" Text="游戏" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="GameCombo" Width="260" Margin="8,0,12,0" DisplayMemberPath="Name" SelectionChanged="Filter_Changed"/>
            <Button Content="扫描游戏目录变化" Click="Scan_Click" Padding="14,8" Margin="4"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#59636E" Margin="12,0,0,0" TextWrapping="Wrap"/>
        </DockPanel>

        <TabControl x:Name="ManagementTabs" Grid.Row="1">
            <TabItem Header="存档候选">
                <Grid Margin="8">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8"><TextBlock Text="处理状态" VerticalAlignment="Center"/><ComboBox x:Name="DecisionCombo" Width="110" Margin="8,0" SelectionChanged="Filter_Changed"/></WrapPanel>
                    <DataGrid x:Name="CandidateGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Extended" SelectionUnit="FullRow" MouseDoubleClick="CandidateGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="游戏" Binding="{Binding GameName}" Width="140"/>
                            <DataGridTextColumn Header="变化" Binding="{Binding ChangeType}" Width="65"/>
                            <DataGridTextColumn Header="处理状态" Binding="{Binding Decision}" Width="80"/>
                            <DataGridTextColumn Header="已确认规则" Binding="{Binding PreviouslyConfirmedText}" Width="85"/>
                            <DataGridTextColumn Header="共享目录" Binding="{Binding SharedDirectoryText}" Width="110"/>
                            <DataGridTextColumn Header="快照类型" Binding="{Binding SnapshotKind}" Width="80"/>
                            <DataGridTextColumn Header="文件" Binding="{Binding RelativePath}" Width="3*"/>
                            <DataGridTextColumn Header="大小" Binding="{Binding FileSizeText}" Width="95"/>
                            <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedAt}" Width="150"/>
                            <DataGridTextColumn Header="默认排除原因" Binding="{Binding DefaultExcludedText}" Width="2*"/>
                            <DataGridTextColumn Header="发现时间" Binding="{Binding DetectedAt}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="0,10,0,0"><Button Content="确认所选并创建快照" Click="ConfirmCandidates_Click" Padding="14,8" Margin="4"/><Button Content="排除所选具体文件" Click="ExcludeCandidates_Click" Padding="14,8" Margin="4"/><Button Content="确认首次系统扫描完成" Click="CompleteInitialScan_Click" Padding="14,8" Margin="4"/><Button Content="预览文件" Click="PreviewCandidate_Click" Padding="14,8" Margin="4"/><Button Content="在资源管理器中定位" Click="LocateCandidate_Click" Padding="14,8" Margin="4"/></WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="本地快照">
                <Grid Margin="8">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8"><TextBlock Text="快照类型" VerticalAlignment="Center"/><ComboBox x:Name="SnapshotKindCombo" Width="110" Margin="8,0,16,0" SelectionChanged="Filter_Changed"/><TextBlock Width="720" Text="恢复说明：先关闭游戏，将快照文件按相对路径人工复制到游戏目录或对应存档目录；跨版本恢复前请自行确认兼容性。" VerticalAlignment="Center" Foreground="#8A5A00" TextWrapping="Wrap"/></WrapPanel>
                    <DataGrid x:Name="SnapshotGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="游戏" Binding="{Binding GameName}" Width="150"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding SnapshotKind}" Width="70"/>
                            <DataGridTextColumn Header="文件数" Binding="{Binding FileCount}" Width="70"/>
                            <DataGridTextColumn Header="总体积" Binding="{Binding TotalSizeText}" Width="95"/>
                            <DataGridTextColumn Header="校验" Binding="{Binding VerifiedText}" Width="80"/>
                            <DataGridTextColumn Header="保留提示" Binding="{Binding CleanupSuggestionText}" Width="90"/>
                            <DataGridTextColumn Header="退出代码" Binding="{Binding ExitCode, TargetNullValue=未知}" Width="80"/>
                            <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="150"/>
                            <DataGridTextColumn Header="目录" Binding="{Binding DirectoryPath}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="0,10,0,0"><Button Content="打开当前存档" Click="OpenCurrentSave_Click" Padding="14,8" Margin="4"/><Button Content="查看当前清单" Click="OpenCurrentManifest_Click" Padding="14,8" Margin="4"/><Button Content="打开快照目录" Click="OpenSnapshot_Click" Padding="14,8" Margin="4"/><Button Content="查看快照清单" Click="OpenManifest_Click" Padding="14,8" Margin="4"/><Button Content="删除快照" Click="DeleteSnapshot_Click" Padding="14,8" Margin="4"/></WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>
        <Button Grid.Row="2" Content="关闭" IsCancel="True" HorizontalAlignment="Right" Padding="20,8" Margin="0,12,0,0"/>
    </Grid>
</Window>
